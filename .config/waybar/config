{
  "layer": "bot",
  "spacing": -2,
  "height": 18,
  "margin-bottom": 0,
  "margin-top": 4,
  "margin-left": 4,
  "margin-right": 4,
  "position": "top",
  "modules-left": ["hyprland/workspaces", "network", "custom/RW", "custom/LOCKIN", "custom/notification_script", "custom/loading"],
  "modules-center": ["clock", "tray"],
  "modules-right": ["custom/weather", "pulseaudio", "cpu", "custom/gpu", "memory"],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "hyprctl dispatch workspace {name}"
  },

  "custom/notification_script": {
    "format": " {}",
    "exec": "~/Everything/scripts/toggle-notifications.sh",
    "interval": 1
  },

  "custom/applauncher": {
    "format": "o",
    "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun",
    "tooltip": true
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "{:%A, %d %B %Y}",
    "interval": 60
  },

  "custom/weather": {
      "format": "{}",
      "exec": "~/Everything/scripts/weather.sh",
      "interval": 120,
      "tooltip": false
  },

  "cpu": {
    "format": "CPU: {usage}%"
  },

  "custom/gpu": {
    "exec": "cat /sys/class/hwmon/hwmon7/device/gpu_busy_percent",
    "format": "GPU: {}%",
    "return-type": "",
    "interval": 1
  },

  "memory": {
    "format": "RAM: {}%"
  },

  "network": {
    "format": "{ifname}",
    "format-disconnected": "⚠ Disconnected",
    "format-wifi": "ᯤ {signalStrength}%"
  },

  "custom/RW": {
    "format": "ᯤ⚠",
    "on-click": "sudo /home/herohunter/Everything/scripts/driverscript.sh",
    "tooltip": true,
    "tooltip-format": "Reset wifi drivers"
  },

  "custom/LOCKIN": {
    "format": "LOCK IN",
    "on-click": "bash -c '/home/herohunter/Everything/scripts/togglelockin.sh'"
  },

  "pulseaudio": {
    "format": "🕪 {volume}% ",
    "format-muted": "MUTED"
  },

  "custom/loading": {
    "exec": "~/Everything/scripts/loading.sh",
    "format": "{}",
  }
}
